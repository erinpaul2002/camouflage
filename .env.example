# ==========================================
# BlendQuest Environment Variables Example
# ==========================================

# ------------------------------------------
# Frontend (Client)
# ------------------------------------------
# The URL where the backend WebSocket server is running.
# Local development default is http://localhost:3001
VITE_SERVER_URL=http://localhost:3001

# ------------------------------------------
# Backend (Server)
# ------------------------------------------
# The port the backend server will listen on.
# Render automatically provides a PORT variable in production.
PORT=3001

# The URL of your frontend. Used to allow WebSocket connections.
# Local development default is http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# (Optional) Game engine tick rate in Hz. Default is usually set in code.
# TICK_HZ=20
